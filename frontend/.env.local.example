# ── ContractSentinel frontend env ────────────────────────────────────────────
# Copy to .env.local for local dev. Only NEXT_PUBLIC_* vars reach the browser.

# CLIENT (browser) — base URL the API client uses. Leave EMPTY for same-origin,
# which routes through the Next.js dev proxy (see next.config.mjs). Set an absolute
# URL only for a non-proxied deployment.
NEXT_PUBLIC_API_BASE_URL=

# CLIENT (browser) — which API provider the seam returns: "mock" (static fixtures,
# zero network) or "real" (fetch/EventSource against the backend). Default: mock.
NEXT_PUBLIC_API_PROVIDER=mock

# SERVER only (NOT NEXT_PUBLIC_) — where the Next dev proxy forwards /api/* in dev.
API_PROXY_ORIGIN=http://127.0.0.1:8000
